{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "paths": {
      "@/*": ["src/*"],
      "@app/*": ["src/app/*"],
      "@config/*": ["src/config/*"],
      "@mail/*": ["src/mail/*"],
      "@database/*": ["src/database/*"],
      "@users/*": ["src/users/*"],
      "@alertas/*": ["src/alertas/*"],
      "@veiculos/*": ["src/veiculos/*"],
      "@objetos/*": ["src/veiculos/*"],
      "@brazilian_person/*": ["src/brazilian_person/*"],
      "@estados/*": ["src/estados/*"],
      "@cities/*": ["src/cities/*"]
    },
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false
  }
}
